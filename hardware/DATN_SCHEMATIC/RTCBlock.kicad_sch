	(text "- Chân 32KHz Dùng để xuất xung ra ngoài phòng trường hợp có ngoại \nvi cần sử dụng xung chuẩn xác từ thời gian thực, vì không \ncần xuất xung để diều khiển nên bỏ"
		(exclude_from_sim no)
		(at 182.118 74.676 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "11ffb82d-0d93-4041-9864-2c36ad537153")
	)
	(text "- Chân RST: Là chân reset ds3231, \ndùng khi cần phải reset trực tiếp bằng phần cứng như nút nhấn\nhoặc dùng để giám sát nguồn, từ đó đưa ra lệnh reset MCU,\nví dụ khi nào hết pin thì sẽ reset MCU vì khi nguồn thấp hơn \nngưỡng giám sát của DS3231 thì sẽ kéo chân RST xuống LOW"
		(exclude_from_sim no)
		(at 182.372 98.552 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "1d8654a8-c999-41c1-b4bc-86ac2c23057e")
	)
